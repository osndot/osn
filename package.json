{
    "name": "osn",
    "version": "0.1.2",
    "description": "Modern, plugin-driven developer runtime and CLI platform.",
    "author": "osndot",
    "license": "MIT",
    "private": true,
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/osndot/osn.git"
    },
    "homepage": "https://github.com/osndot/osn#readme",
    "bugs": {
        "url": "https://github.com/osndot/osn/issues"
    },
    "scripts": {
        "build": "pnpm -r run build",
        "dev": "pnpm -r run dev",
        "test": "pnpm -r run test",
        "lint": "eslint packages/*/src/**/*.ts",
        "lint:fix": "eslint packages/*/src/**/*.ts --fix",
        "format": "prettier --write \"packages/*/src/**/*.ts\"",
        "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
        "typecheck": "pnpm -r exec tsc --noEmit",
        "clean": "pnpm -r exec rimraf dist"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.0.3",
        "prettier": "^3.8.1",
        "rimraf": "^6.0.1",
        "tsup": "^8.4.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.57.0",
        "vitest": "^3.0.5"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "packageManager": "pnpm@9.15.4"
}