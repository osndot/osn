{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "OSN Project Configuration",
    "description": "Configuration file for an OSN project, stored at .osn/project.json",
    "type": "object",
    "required": [
        "name"
    ],
    "properties": {
        "$schema": {
            "type": "string",
            "description": "JSON Schema reference URL"
        },
        "name": {
            "type": "string",
            "minLength": 1,
            "description": "Project name"
        },
        "version": {
            "type": "string",
            "default": "0.1.0",
            "description": "Project version (semver)"
        },
        "plugins": {
            "type": "array",
            "default": [],
            "description": "List of installed OSN plugins",
            "items": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Plugin npm package name (e.g. @osndot/plugin-git)"
                    },
                    "version": {
                        "type": "string",
                        "description": "Plugin version"
                    },
                    "config": {
                        "type": "object",
                        "description": "Plugin-specific configuration",
                        "additionalProperties": true
                    }
                }
            }
        },
        "tasks": {
            "type": "object",
            "default": {},
            "description": "Task definitions",
            "additionalProperties": {
                "type": "object",
                "required": [
                    "command"
                ],
                "properties": {
                    "command": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Shell command to execute"
                    },
                    "description": {
                        "type": "string",
                        "description": "Human-readable task description"
                    },
                    "env": {
                        "type": "object",
                        "description": "Environment variables for this task",
                        "additionalProperties": {
                            "type": "string"
                        }
                    },
                    "dependsOn": {
                        "type": "array",
                        "description": "Task names that must run before this task",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "runtime": {
            "type": "object",
            "description": "Runtime configuration",
            "properties": {
                "nodeVersion": {
                    "type": "string",
                    "description": "Required Node.js version (semver range)"
                }
            }
        }
    }
}