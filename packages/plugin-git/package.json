{
    "name": "@osndot/plugin-git",
    "version": "0.2.0",
    "description": "Git integration plugin for the OSN CLI platform",
    "author": "osndot",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/osndot/osn.git",
        "directory": "packages/plugin-git"
    },
    "homepage": "https://github.com/osndot/osn/tree/main/packages/plugin-git#readme",
    "bugs": {
        "url": "https://github.com/osndot/osn/issues"
    },
    "main": "./dist/index.js",
